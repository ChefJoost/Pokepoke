{
  "name": "pokepoke",
  "version": "1.0.0",
  "description": "Pokémon kaartencollectie tracker",
  "main": "server/index.js",
  "scripts": {
    "dev": "vite client --port 5173",
    "build": "vite build client",
    "cap:add": "npx cap add android",
