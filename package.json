    "@capacitor/core": "^8.4.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dexie": "^4.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "vite": "^5.1.4"
  }
}
